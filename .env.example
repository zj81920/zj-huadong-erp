# ============================
# 数据库配置
# ============================

# 本地开发：Docker PostgreSQL（端口 5433）
DATABASE_URL="postgresql://<用户名>:<密码>@localhost:5433/huadong_erp?schema=public"

# ============================
# 文件存储配置
# ============================

# 存储模式：local（本地）| oss（阿里云OSS）
STORAGE_MODE="oss"

# 本地存储目录（STORAGE_MODE=local 时生效）
UPLOAD_DIR="./uploads"

# ============================
# 阿里云 OSS 配置
# ============================

OSS_REGION="oss-cn-shanghai"
OSS_ACCESS_KEY_ID="<替换为RAM用户的AccessKey ID>"
OSS_ACCESS_KEY_SECRET="<替换为RAM用户的AccessKey Secret>"
OSS_BUCKET="<替换为Bucket名称>"

# ============================
# 应用配置
# ============================

APP_SECRET="<替换为随机密钥，用于Session加密>"
APP_URL="http://localhost:3000"
