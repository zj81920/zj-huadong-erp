generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== 基础/系统表 ====================

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  password     String
  realName     String   @map("real_name")
  phone        String?
  email        String?
  role         String   @default("staff")
  department   String?
  signatureUrl String?  @map("signature_url")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  expenseReportsAsApplicant  ExpenseReport[]       @relation("ExpenseReportApplicant")
  loanRequestsAsApplicant    LoanRequest[]         @relation("LoanRequestApplicant")
  paymentApplications        PaymentApplication[]   @relation("PaymentApplicationApplicant")
  approvalActions            ApprovalAction[]
  designTasksAssigned        DesignTask[]
  projectPlansResponsible    ProjectPlan[]
  delegatedByMe              ApprovalDelegate[]     @relation("Delegator")
  delegatedToMe              ApprovalDelegate[]     @relation("DelegateTo")
  projectsAsDesignManager    Project[]              @relation("DesignManager")
  projectsAsSupervisorLeader Project[]              @relation("SupervisorLeader")
  salaryPayments             SalaryPayment[]
  userRoles                  UserRole[]

  @@map("users")
}

model Role {
  id            String   @id @default(cuid())
  code          String   @unique
  name          String
  description   String?
  isProjectRole Boolean  @default(false) @map("is_project_role")
  sort          Int      @default(0)
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  users         UserRole[]

  @@map("roles")
}

model UserRole {
  id     String @id @default(cuid())
  userId String @map("user_id")
  roleId String @map("role_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model Supplier {
  id               String   @id @default(cuid())
  name             String   @unique
  supplierType     String   @default("企业") @map("supplier_type")
  status           String   @default("当前有效") @map("status")
  contactPerson    String?  @map("contact_person")
  phone            String?
  email            String?
  address          String?
  bankName         String?  @map("bank_name")
  bankAccount      String?  @map("bank_account")
  remark           String?
  attachmentUrl    String?  @map("attachment_url")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  purchaseContracts PurchaseContract[]
  expenseContracts  ExpenseContract[]
  outsourcingTasks  OutsourcingTask[]

  @@map("suppliers")
}

model Customer {
  id            String   @id @default(cuid())
  name          String
  address       String?
  contactPerson String?  @map("contact_person")
  phone         String?
  email         String?
  maintainer    String?
  industryType  String?  @map("industry_type")
  customerGrade String?  @default("C") @map("customer_grade")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  projectLeads    ProjectLead[]
  projects        Project[]
  quotations      Quotation[]
  incomeContracts IncomeContract[]

  @@map("customers")
}

// ==================== 商务管理 ====================

model ProjectLead {
  id                  String    @id @default(cuid())
  projectSourceId     String    @unique @map("project_source_id")
  customerId          String    @map("customer_id")
  projectName         String    @map("project_name")
  location            String?
  estimatedInvestment Decimal?  @map("estimated_investment") @db.Decimal(15, 2)
  bidReleaseTime      DateTime? @map("bid_release_time")
  infoSource          String?   @map("info_source")
  currentStatus       String    @default("潜在") @map("current_status")
  followUpRecords     Json      @default("[]") @map("follow_up_records")
  competitorInfo      Json      @default("[]") @map("competitor_info")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  customer   Customer     @relation(fields: [customerId], references: [id])
  project    Project?
  biddings   Bidding[]
  quotations Quotation[]

  @@map("project_leads")
}

model Bidding {
  id                String    @id @default(cuid())
  projectSourceId   String    @map("project_source_id")
  tenderFileReg     String?   @map("tender_file_registration")
  bidDeadline       DateTime? @map("bid_deadline")
  bondAmount        Decimal?  @map("bond_amount") @db.Decimal(15, 2)
  bondPaymentStatus String    @default("未付") @map("bond_payment_status")
  bidResult         String?   @map("bid_result")
  bidAmount         Decimal?  @map("bid_amount") @db.Decimal(15, 2)
  score             Decimal?
  failReason        String?   @map("fail_reason")
  attachmentUrl     String?   @map("attachment_url")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  projectLead ProjectLead @relation(fields: [projectSourceId], references: [projectSourceId])

  @@map("biddings")
}

model Quotation {
  id                String   @id @default(cuid())
  projectSourceId   String?  @map("project_source_id")
  customerId        String   @map("customer_id")
  estimatedCost     Json     @default("{}") @map("estimated_cost")
  totalAmount       Decimal  @map("total_amount") @db.Decimal(15, 2)
  profitMargin      Decimal? @map("profit_margin") @db.Decimal(5, 2)
  approvalStatus    String   @default("草稿") @map("approval_status")
  version           Int      @default(1)
  adjustmentReason  String?  @map("adjustment_reason")
  status            String   @default("跟踪") @map("status")
  approvalInstanceId String? @map("approval_instance_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  customer    Customer     @relation(fields: [customerId], references: [id])
  projectLead ProjectLead? @relation(fields: [projectSourceId], references: [projectSourceId])

  @@map("quotations")
}

// ==================== 项目管理 ====================

model Project {
  id                String    @id @default(cuid())
  projectSourceId   String    @unique @map("project_source_id")
  projectCode       String    @unique @map("project_code")
  name              String
  customerId        String    @map("customer_id")
  type              String?
  address           String?
  projectCategory   String?   @map("project_category")
  source            String    @default("投标中标")
  sourceRefId       String?   @map("source_ref_id")
  status            String    @default("筹备")
  designManagerId   String?   @map("design_manager_id")
  supervisorLeaderId String?  @map("supervisor_leader_id")
  startDate         DateTime? @map("start_date")
  plannedEndDate    DateTime? @map("planned_end_date")
  actualCloseDate   DateTime? @map("actual_close_date")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  customer             Customer           @relation(fields: [customerId], references: [id])
  projectLead          ProjectLead        @relation(fields: [projectSourceId], references: [projectSourceId])
  designManager        User?              @relation("DesignManager", fields: [designManagerId], references: [id])
  supervisorLeader     User?              @relation("SupervisorLeader", fields: [supervisorLeaderId], references: [id])
  plans                ProjectPlan[]
  progressRecords     ProjectProgress[]
  designTasks         DesignTask[]
  outsourcingTasks    OutsourcingTask[]
  purchaseRequests    PurchaseRequest[]
  budgets             ProjectBudget[]
  incomeContracts     IncomeContract[]
  expenseContracts    ExpenseContract[]
  expenseReports      ExpenseReport[]
  receivables         Receivable[]
  payables            Payable[]
  nonContractIncomes  NonContractIncome[]
  nonContractExpenses NonContractExpense[]

  @@map("projects")
}

model ProjectPlan {
  id              String   @id @default(cuid())
  projectSourceId String   @map("project_source_id")
  planType        String   @map("plan_type")
  planContent     String   @map("plan_content") @db.Text
  startDate       DateTime @map("start_date")
  endDate         DateTime @map("end_date")
  responsibleId   String?  @map("responsible_id")
  actualProgress  Int      @default(0) @map("actual_progress")
  status          String   @default("未开始")
  version         Int      @default(1)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  project           Project @relation(fields: [projectSourceId], references: [projectSourceId])
  responsiblePerson User?   @relation(fields: [responsibleId], references: [id])

  @@map("project_plans")
}

model ProjectProgress {
  id                String   @id @default(cuid())
  projectSourceId   String   @map("project_source_id")
  taskNode          String   @map("task_node")
  plannedPercentage Int      @default(0) @map("planned_percentage")
  actualPercentage  Int      @default(0) @map("actual_percentage")
  delayDays         Int      @default(0) @map("delay_days")
  alertStatus       String   @default("正常") @map("alert_status")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectSourceId], references: [projectSourceId])

  @@map("project_progress")
}

model DesignTask {
  id              String    @id @default(cuid())
  projectSourceId String    @map("project_source_id")
  discipline      String?
  volume          String?
  drawingNo       String?   @map("drawing_no")
  assignedTo      String?   @map("assigned_to")
  plannedHours    Decimal?  @map("planned_hours") @db.Decimal(8, 1)
  actualHours     Decimal?  @map("actual_hours") @db.Decimal(8, 1)
  fileLink        String?   @map("file_link")
  changeRecord    Json      @default("[]") @map("change_record")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  project  Project @relation(fields: [projectSourceId], references: [projectSourceId])
  assignee User?   @relation(fields: [assignedTo], references: [id])

  @@map("design_tasks")
}

model OutsourcingTask {
  id                 String   @id @default(cuid())
  projectSourceId    String   @map("project_source_id")
  type               String   @default("to_person")
  targetName         String   @map("target_name")
  supplierId         String?  @map("supplier_id")
  contractId         String?  @map("contract_id")
  taskDescription    String   @map("task_description") @db.Text
  workload           String?
  deliveryDeadline   DateTime @map("delivery_deadline")
  amount             Decimal  @db.Decimal(15, 2)
  acceptanceStatus   String   @default("未验收") @map("acceptance_status")
  approvalStatus     String   @default("草稿") @map("approval_status")
  approvalInstanceId String?  @map("approval_instance_id")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  project  Project  @relation(fields: [projectSourceId], references: [projectSourceId])
  supplier Supplier? @relation(fields: [supplierId], references: [id])

  @@map("outsourcing_tasks")
}

// ==================== 采购管理 ====================

model PurchaseRequest {
  id                 String    @id @default(cuid())
  requestNo          String    @unique @map("request_no")
  projectSourceId    String    @map("project_source_id")
  requestType        String    @default("项目需求") @map("request_type")
  requiredDate       DateTime? @map("required_date")
  status             String    @default("草稿")
  approvalInstanceId String?   @map("approval_instance_id")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  project Project  @relation(fields: [projectSourceId], references: [projectSourceId])
  inquiry Inquiry?
  items   PurchaseRequestItem[]

  @@map("purchase_requests")
}

model PurchaseRequestItem {
  id                String    @id @default(cuid())
  purchaseRequestId String    @map("purchase_request_id")
  materialName      String    @map("material_name")
  spec              String?
  material          String?
  brand             String?
  standardNo        String?   @map("standard_no")
  unit              String?
  quantity          Decimal?  @db.Decimal(15, 2)
  remark            String?   @db.Text
  sortOrder         Int       @default(0) @map("sort_order")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  purchaseRequest PurchaseRequest @relation(fields: [purchaseRequestId], references: [id], onDelete: Cascade)

  @@map("purchase_request_items")
}

model Inquiry {
  id                    String    @id @default(cuid())
  purchaseRequestId     String    @unique @map("purchase_request_id")
  projectSourceId       String    @map("project_source_id")
  supplierIds           Json      @default("[]") @map("supplier_ids")
  inquiryDate           DateTime  @default(now()) @map("inquiry_date")
  closingDate           DateTime? @map("closing_date")
  quoteSummary          Json      @default("{}") @map("quote_summary")
  recommendedSupplierId String?   @map("recommended_supplier_id")
  isSingleSource        Boolean   @default(false) @map("is_single_source")
  singleSourceReason    String?   @map("single_source_reason") @db.Text
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  purchaseRequest  PurchaseRequest   @relation(fields: [purchaseRequestId], references: [id])
  purchaseContract PurchaseContract?
  expenseContract  ExpenseContract?

  @@map("inquiries")
}

model PurchaseContract {
  id                 String    @id @default(cuid())
  contractNo         String    @unique @map("contract_no")
  projectSourceId    String    @map("project_source_id")
  supplierId         String    @map("supplier_id")
  inquiryId          String?   @unique @map("inquiry_id")
  totalAmount        Decimal   @map("total_amount") @db.Decimal(15, 2)
  paymentTerms       String?   @map("payment_terms") @db.Text
  signedDate         DateTime? @map("signed_date")
  status             String    @default("草稿")
  approvalInstanceId String?   @map("approval_instance_id")
  scannedUrl         String?   @map("scanned_url")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  inquiry          Inquiry?        @relation(fields: [inquiryId], references: [id])
  supplier         Supplier        @relation(fields: [supplierId], references: [id])
  deliveryReceipts DeliveryReceipt[]

  @@map("purchase_contracts")
}

model DeliveryReceipt {
  id                 String   @id @default(cuid())
  purchaseContractId String   @map("purchase_contract_id")
  deliveryDate       DateTime @default(now()) @map("delivery_date")
  receivedQuantity   String   @map("received_quantity")
  inspectionResult   String   @default("待检") @map("inspection_result")
  receiptStatus      String   @default("待验收") @map("receipt_status")
  invoiceMatched     Boolean  @default(false) @map("invoice_matched")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  purchaseContract PurchaseContract @relation(fields: [purchaseContractId], references: [id])

  @@map("delivery_receipts")
}

// ==================== 合同管理 ====================

model IncomeContract {
  id                 String    @id @default(cuid())
  contractNo         String    @unique @map("contract_no")
  projectSourceId    String?   @map("project_source_id")
  customerId         String    @map("customer_id")
  signedDate         DateTime? @map("signed_date")
  totalAmount        Decimal   @map("total_amount") @db.Decimal(15, 2)
  splitStages        Json      @default("[]") @map("split_stages")
  status             String    @default("草稿")
  approvalInstanceId String?   @map("approval_instance_id")
  scannedUrl         String?   @map("scanned_url")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  customer Customer @relation(fields: [customerId], references: [id])
  project  Project? @relation(fields: [projectSourceId], references: [projectSourceId])

  @@map("income_contracts")
}

model ExpenseContract {
  id                 String    @id @default(cuid())
  contractNo         String    @unique @map("contract_no")
  projectSourceId    String?   @map("project_source_id")
  supplierId         String?   @map("supplier_id")
  inquiryId          String?   @unique @map("inquiry_id")
  signedDate         DateTime? @map("signed_date")
  totalAmount        Decimal   @map("total_amount") @db.Decimal(15, 2)
  paymentTerms       String?   @map("payment_terms") @db.Text
  status             String    @default("草稿")
  contractType       String    @default("其他") @map("contract_type")
  approvalInstanceId String?   @map("approval_instance_id")
  scannedUrl         String?   @map("scanned_url")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  supplier  Supplier?  @relation(fields: [supplierId], references: [id])
  project   Project?   @relation(fields: [projectSourceId], references: [projectSourceId])
  inquiry   Inquiry?   @relation(fields: [inquiryId], references: [id])

  @@map("expense_contracts")
}

model NonContractIncome {
  id                 String   @id @default(cuid())
  projectSourceId    String?  @map("project_source_id")
  amount             Decimal  @db.Decimal(15, 2)
  transactionDate    DateTime @default(now()) @map("transaction_date")
  counterparty       String?
  description        String?  @db.Text
  approvalInstanceId String?  @map("approval_instance_id")
  status             String   @default("草稿")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  project     Project?     @relation(fields: [projectSourceId], references: [projectSourceId])

  @@map("non_contract_incomes")
}

model NonContractExpense {
  id                 String   @id @default(cuid())
  projectSourceId    String?  @map("project_source_id")
  amount             Decimal  @db.Decimal(15, 2)
  transactionDate    DateTime @default(now()) @map("transaction_date")
  counterparty       String?
  description        String?  @db.Text
  approvalInstanceId String?  @map("approval_instance_id")
  status             String   @default("草稿")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  project   Project?   @relation(fields: [projectSourceId], references: [projectSourceId])

  @@map("non_contract_expenses")
}

// ==================== 费用管理 ====================

model ProjectBudget {
  id                 String   @id @default(cuid())
  projectSourceId    String   @map("project_source_id")
  budgetItems        Json     @default("[]") @map("budget_items")
  approvalStatus     String   @default("草稿") @map("approval_status")
  version            Int      @default(1)
  approvalInstanceId String?  @map("approval_instance_id")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectSourceId], references: [projectSourceId])

  @@map("project_budgets")
}

model ExpenseReport {
  id                 String   @id @default(cuid())
  projectSourceId    String?  @map("project_source_id")
  applicantId        String   @map("applicant_id")
  expenseType        String   @map("expense_type")
  amount             Decimal  @db.Decimal(15, 2)
  description        String?  @db.Text
  attachmentUrl      String?  @map("attachment_url")
  budgetCategory     String?  @map("budget_category")
  status             String   @default("草稿")
  approvalInstanceId String?  @map("approval_instance_id")
  loanOffsetAmount   Decimal  @default(0) @map("loan_offset_amount") @db.Decimal(15, 2)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  project   Project? @relation(fields: [projectSourceId], references: [projectSourceId])
  applicant User     @relation("ExpenseReportApplicant", fields: [applicantId], references: [id])
  items     ExpenseReportItem[]

  @@map("expense_reports")
}

model ExpenseReportItem {
  id              String   @id @default(cuid())
  reportId        String   @map("report_id")
  expenseType     String   @map("expense_type")
  amount          Decimal  @db.Decimal(15, 2)
  description     String?  @db.Text
  projectSourceId String?  @map("project_source_id")
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at")

  report ExpenseReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@map("expense_report_items")
}

model LoanRequest {
  id                 String   @id @default(cuid())
  applicantId        String   @map("applicant_id")
  amount             Decimal  @db.Decimal(15, 2)
  reason             String?  @db.Text
  expectedReturnDate DateTime @map("expected_return_date")
  status             String   @default("草稿")
  approvalInstanceId String?  @map("approval_instance_id")
  repaidAmount       Decimal  @default(0) @map("repaid_amount") @db.Decimal(15, 2)
  remainingAmount    Decimal  @db.Decimal(15, 2) @map("remaining_amount")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  applicant User      @relation("LoanRequestApplicant", fields: [applicantId], references: [id])

  @@map("loan_requests")
}

// ==================== 财务管理 ====================

// Receivable 和 Payable 采用多态设计：
// sourceType + sourceId 标识来源（不建外键，由应用层保证一致性）
// projectSourceId 关联项目（建外键）

model Receivable {
  id              String   @id @default(cuid())
  sourceType      String   @map("source_type")
  sourceId        String   @map("source_id")
  projectSourceId String?  @map("project_source_id")
  dueDate         DateTime @map("due_date")
  amount          Decimal  @db.Decimal(15, 2)
  paidAmount      Decimal  @default(0) @map("paid_amount") @db.Decimal(15, 2)
  invoicedAmount  Decimal  @default(0) @map("invoiced_amount") @db.Decimal(15, 2)
  status          String   @default("未收")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  project         Project?         @relation(fields: [projectSourceId], references: [projectSourceId])
  receiptVouchers ReceiptVoucher[]

  @@map("receivables")
}

model Payable {
  id              String   @id @default(cuid())
  sourceType      String   @map("source_type")
  sourceId        String   @map("source_id")
  projectSourceId String?  @map("project_source_id")
  dueDate         DateTime @map("due_date")
  amount          Decimal  @db.Decimal(15, 2)
  paidAmount      Decimal  @default(0) @map("paid_amount") @db.Decimal(15, 2)
  invoicedAmount  Decimal  @default(0) @map("invoiced_amount") @db.Decimal(15, 2)
  status          String   @default("未付")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  project              Project?             @relation(fields: [projectSourceId], references: [projectSourceId])
  paymentApplications  PaymentApplication[]

  @@map("payables")
}

model PaymentApplication {
  id                 String   @id @default(cuid())
  payableId          String   @map("payable_id")
  applicantId        String   @map("applicant_id")
  amount             Decimal  @db.Decimal(15, 2)
  paymentReason      String?  @map("payment_reason")
  paymentMethod      String?  @map("payment_method")
  bankAccount        String?  @map("bank_account")
  remark             String?
  approvalStatus     String   @default("草稿") @map("approval_status")
  approvalInstanceId String?  @map("approval_instance_id")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  payable         Payable          @relation(fields: [payableId], references: [id])
  applicant       User             @relation("PaymentApplicationApplicant", fields: [applicantId], references: [id])
  paymentVouchers PaymentVoucher[]

  @@map("payment_applications")
}

model ReceiptVoucher {
  id              String    @id @default(cuid())
  receivableId    String    @map("receivable_id")
  receiptNo       String?   @map("receipt_no")
  registrant      String?   @map("registrant")
  registerDate    DateTime? @map("register_date")
  amount          Decimal   @db.Decimal(15, 2)
  receiptDate     DateTime  @default(now()) @map("receipt_date")
  receiptReason   String?   @map("receipt_reason")
  receiptMethod   String?   @map("receipt_method")
  bankAccount     String?   @map("bank_account")
  attachments     String?   @map("attachments")
  remark          String?
  createdAt       DateTime  @default(now()) @map("created_at")

  receivable Receivable @relation(fields: [receivableId], references: [id])

  @@map("receipt_vouchers")
}

model PaymentVoucher {
  id                   String    @id @default(cuid())
  paymentApplicationId String    @map("payment_application_id")
  paymentNo            String?   @map("payment_no")
  registrant           String?   @map("registrant")
  registerDate         DateTime? @map("register_date")
  amount               Decimal   @db.Decimal(15, 2)
  paymentDate          DateTime  @default(now()) @map("payment_date")
  paymentReason        String?   @map("payment_reason")
  paymentMethod        String?   @map("payment_method")
  bankAccount          String?   @map("bank_account")
  attachments          String?   @map("attachments")
  remark               String?
  createdAt            DateTime  @default(now()) @map("created_at")

  paymentApplication PaymentApplication @relation(fields: [paymentApplicationId], references: [id])

  @@map("payment_vouchers")
}

// ==================== 股东出资管理 ====================

model Shareholder {
  id           String    @id @default(cuid())
  name         String
  idNumber     String?   @map("id_number")
  shareRatio   Decimal?  @map("share_ratio") @db.Decimal(5, 2)
  contactPhone String?   @map("contact_phone")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  contributions CapitalContribution[]
  equityChanges EquityChange[]

  @@map("shareholders")
}

model CapitalContribution {
  id              String   @id @default(cuid())
  shareholderId   String   @map("shareholder_id")
  amount          Decimal  @db.Decimal(15, 2)
  returnedAmount  Decimal  @default(0) @map("returned_amount") @db.Decimal(15, 2)
  remainingAmount Decimal  @db.Decimal(15, 2) @map("remaining_amount")
  contributeDate  DateTime @map("contribute_date")
  method          String?
  remark          String?
  createdAt       DateTime @default(now()) @map("created_at")

  shareholder Shareholder    @relation(fields: [shareholderId], references: [id])
  returns     CapitalReturn[]

  @@map("capital_contributions")
}

model CapitalReturn {
  id             String   @id @default(cuid())
  contributionId String   @map("contribution_id")
  amount         Decimal  @db.Decimal(15, 2)
  returnDate     DateTime @map("return_date")
  remark         String?
  createdAt      DateTime @default(now()) @map("created_at")

  contribution CapitalContribution @relation(fields: [contributionId], references: [id])

  @@map("capital_returns")
}

model EquityChange {
  id             String    @id @default(cuid())
  shareholderId  String    @map("shareholder_id")
  changeType     String    @map("change_type")
  beforeRatio    Decimal?  @map("before_ratio") @db.Decimal(5, 2)
  afterRatio     Decimal?  @map("after_ratio") @db.Decimal(5, 2)
  changeDate     DateTime  @map("change_date")
  remark         String?
  createdAt      DateTime  @default(now()) @map("created_at")

  shareholder Shareholder @relation(fields: [shareholderId], references: [id])

  @@map("equity_changes")
}

// ==================== 其他借入款 ====================

model OtherBorrowing {
  id                 String   @id @default(cuid())
  lenderName         String   @map("lender_name")
  amount             Decimal  @db.Decimal(15, 2)
  returnedAmount     Decimal  @default(0) @map("returned_amount") @db.Decimal(15, 2)
  remainingAmount    Decimal  @db.Decimal(15, 2) @map("remaining_amount")
  borrowingDate      DateTime @map("borrowing_date")
  expectedReturnDate DateTime? @map("expected_return_date")
  description        String?  @db.Text
  status             String   @default("未还清") @map("status")
  approvalInstanceId String?  @map("approval_instance_id")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  returns BorrowingReturn[]

  @@map("other_borrowings")
}

model BorrowingReturn {
  id          String   @id @default(cuid())
  borrowingId String   @map("borrowing_id")
  amount      Decimal  @db.Decimal(15, 2)
  returnDate  DateTime @map("return_date")
  remark      String?
  createdAt   DateTime @default(now()) @map("created_at")

  borrowing OtherBorrowing @relation(fields: [borrowingId], references: [id])

  @@map("borrowing_returns")
}

// ==================== 借出款 ====================

model LendingOut {
  id                 String   @id @default(cuid())
  lendingType        String   @map("lending_type")
  projectSourceId    String?  @map("project_source_id")
  biddingId          String?  @map("bidding_id")
  borrowerName       String   @map("borrower_name")
  amount             Decimal  @db.Decimal(15, 2)
  returnedAmount     Decimal  @default(0) @map("returned_amount") @db.Decimal(15, 2)
  remainingAmount    Decimal  @db.Decimal(15, 2) @map("remaining_amount")
  lendingDate        DateTime @map("lending_date")
  expectedReturnDate DateTime? @map("expected_return_date")
  description        String?  @db.Text
  status             String   @default("草稿") @map("status")
  approvalInstanceId String?  @map("approval_instance_id")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  returns LendingReturn[]

  @@map("lending_outs")
}

model LendingReturn {
  id         String   @id @default(cuid())
  lendingId  String   @map("lending_id")
  amount     Decimal  @db.Decimal(15, 2)
  returnDate DateTime @map("return_date")
  remark     String?
  createdAt  DateTime @default(now()) @map("created_at")

  lending LendingOut @relation(fields: [lendingId], references: [id])

  @@map("lending_returns")
}

// ==================== 工资发放 ====================

model SalaryPayment {
  id                 String    @id @default(cuid())
  employeeId         String    @map("employee_id")
  period             String    @map("period")
  baseSalary         Decimal   @map("base_salary") @db.Decimal(15, 2)
  bonus              Decimal   @default(0) @db.Decimal(15, 2)
  allowance          Decimal   @default(0) @db.Decimal(15, 2)
  deduction          Decimal   @default(0) @db.Decimal(15, 2)
  netSalary         Decimal   @map("net_salary") @db.Decimal(15, 2)
  paymentDate        DateTime? @map("payment_date")
  status             String    @default("草稿") @map("status")
  approvalInstanceId String?   @map("approval_instance_id")
  remark             String?
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  employee User @relation(fields: [employeeId], references: [id])

  @@map("salary_payments")
}

// ==================== 审批流引擎 ====================

model ApprovalFlowDefinition {
  id           String   @id @default(cuid())
  businessType String   @map("business_type")
  flowLevel    String   @default("project") @map("flow_level")
  nodeOrder    Int      @map("node_order")
  nodeName     String   @map("node_name")
  approverRole String   @map("approver_role")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("approval_flow_definitions")
}

model ApprovalInstance {
  id           String   @id @default(cuid())
  businessType String   @map("business_type")
  businessId   String   @map("business_id")
  flowLevel    String   @default("project") @map("flow_level")
  currentNode  Int      @default(0) @map("current_node")
  status       String   @default("审批中")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  actions ApprovalAction[]

  @@map("approval_instances")
}

model ApprovalAction {
  id         String    @id @default(cuid())
  instanceId String    @map("instance_id")
  nodeId     Int       @map("node_id")
  nodeName   String    @map("node_name")
  approverId String    @map("approver_id")
  action     String
  comment    String?
  actedAt    DateTime? @map("acted_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  instance ApprovalInstance @relation(fields: [instanceId], references: [id])
  approver User             @relation(fields: [approverId], references: [id])

  @@map("approval_actions")
}

model ApprovalDelegate {
  id           String   @id @default(cuid())
  delegatorId  String   @map("delegator_id")
  delegateToId String   @map("delegate_to_id")
  startTime    DateTime @map("start_time")
  endTime      DateTime @map("end_time")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  delegator  User @relation("Delegator", fields: [delegatorId], references: [id])
  delegateTo User @relation("DelegateTo", fields: [delegateToId], references: [id])

  @@map("approval_delegates")
}

// ==================== 行政管理 ====================

model OfficeSupply {
  id          String   @id @default(cuid())
  name        String
  category    String?
  spec        String?
  unit        String?
  quantity    Int      @default(0)
  unitPrice   Decimal? @map("unit_price") @db.Decimal(10, 2)
  totalPrice  Decimal? @map("total_price") @db.Decimal(10, 2)
  storeLocation String? @map("store_location")
  remark      String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("office_supplies")
}

model Certificate {
  id            String    @id @default(cuid())
  name          String
  certNo        String?   @map("cert_no")
  certType      String?   @map("cert_type")
  issuer        String?
  issueDate     DateTime? @map("issue_date")
  expireDate    DateTime? @map("expire_date")
  holder        String?
  status        String    @default("有效")
  location      String?
  remark        String?   @db.Text
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("certificates")
}

model Seal {
  id          String   @id @default(cuid())
  name        String
  sealType    String   @map("seal_type")
  custodian   String?
  location    String?
  status      String   @default("在库")
  remark      String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("seals")
}

model BankAccount {
  id          String   @id @default(cuid())
  accountName String   @map("account_name")
  bankName    String   @map("bank_name")
  accountNo   String   @unique @map("account_no")
  accountType String   @map("account_type")
  isActive    Boolean  @default(true) @map("is_active")
  remark      String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("bank_accounts")
}
