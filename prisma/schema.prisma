generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== 基础/系统表 ====================

model Department {
  id        String   @id @default(cuid())
  name      String
  sort      Int      @default(0)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  lastModifiedBy     String?   @map("last_modified_by")

  roles Role[]

  @@map("departments")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  password     String
  realName     String   @map("real_name")
  phone        String?
  email        String?
  role         String   @default("staff")
  department   String?
  signatureUrl String?  @map("signature_url")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  lastModifiedBy     String?   @map("last_modified_by")

  idNumber           String?   @map("id_number")
  birthDate          DateTime? @map("birth_date")
  position           String?
  employmentStatus   String?   @default("active") @map("employment_status")
  hireDate           DateTime? @map("hire_date")
  leaveDate          DateTime? @map("leave_date")
  bankName           String?   @map("bank_name")
  bankAccount        String?   @map("bank_account")
  baseSalary         Decimal?  @map("base_salary") @db.Decimal(15, 2)
  socialInsuranceBase Decimal? @map("social_insurance_base") @db.Decimal(15, 2)
  housingFundBase    Decimal?  @map("housing_fund_base") @db.Decimal(15, 2)
  housingFundRate    Decimal?  @map("housing_fund_rate") @db.Decimal(5, 4)
  socialInsuranceCompanyRate Decimal? @map("social_insurance_company_rate") @db.Decimal(5, 4)
  housingFundCompanyRate     Decimal? @map("housing_fund_company_rate") @db.Decimal(5, 4)
  taxDeduction       Decimal?  @map("tax_deduction") @db.Decimal(15, 2)
  remark             String?

  expenseReportsAsApplicant  ExpenseReport[]       @relation("ExpenseReportApplicant")
  loanRequestsAsApplicant    LoanRequest[]         @relation("LoanRequestApplicant")
  paymentApplications        PaymentApplication[]   @relation("PaymentApplicationApplicant")
  approvalActions            ApprovalAction[]
  designTasksAssigned        DesignTask[]
  projectPlansResponsible    ProjectPlan[]
  delegatedByMe              ApprovalDelegate[]     @relation("Delegator")
  delegatedToMe              ApprovalDelegate[]     @relation("DelegateTo")
  projectsAsDesignManager    Project[]              @relation("DesignManager")
  projectsAsSupervisorLeader Project[]              @relation("SupervisorLeader")
  salaryPayments             SalaryPayment[]
  salaryBatchItems           SalaryBatchItem[]
  userRoles                  UserRole[]
  attachments                EmployeeAttachment[]

  @@map("users")
}

model EmployeeAttachment {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  fileName    String   @map("file_name")
  fileUrl     String   @map("file_url")
  fileType    String   @map("file_type")
  fileSize    Int      @map("file_size")
  createdAt   DateTime @default(now()) @map("created_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("employee_attachments")
}

model Role {
  id            String      @id @default(cuid())
  code          String      @unique
  name          String
  description   String?
  departmentId  String?     @map("department_id")
  isProjectRole      Boolean     @default(false) @map("is_project_role")
  accessibleModules  String      @default("[]") @map("accessible_modules")
  isGlobalVisible    Boolean     @default(false) @map("is_global_visible")
  sort               Int         @default(0)
  isActive           Boolean     @default(true) @map("is_active")
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")
  lastModifiedBy     String?   @map("last_modified_by")

  department Department? @relation(fields: [departmentId], references: [id])
  users      UserRole[]

  @@map("roles")
}

model UserRole {
  id     String @id @default(cuid())
  userId String @map("user_id")
  roleId String @map("role_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model Supplier {
  id               String   @id @default(cuid())
  name             String
  supplierType     String   @default("企业") @map("supplier_type")
  status           String   @default("当前有效") @map("status")
  contactPerson    String?  @map("contact_person")
  phone            String?
  email            String?
  address          String?
  bankName         String?  @map("bank_name")
  bankAccount      String?  @map("bank_account")
  remark           String?
  attachmentUrl    String? @map("attachment_url")
  approvalStatus      String  @default("草稿") @map("approval_status")
  approvalInstanceId  String? @map("approval_instance_id")
  isActive            Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  lastModifiedBy     String?   @map("last_modified_by")

  expenseContracts  ExpenseContract[]
  outsourcingTasks  OutsourcingTask[]
  supplierQuotes    SupplierQuote[]

  @@map("suppliers")
}

model Customer {
  id            String   @id @default(cuid())
  name          String
  address       String?
  contactPerson String?  @map("contact_person")
  phone         String?
  email         String?
  maintainer    String?
  industryType  String?  @map("industry_type")
  customerGrade String?  @default("C") @map("customer_grade")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  lastModifiedBy     String?   @map("last_modified_by")

  projectLeads    ProjectLead[]
  projects        Project[]
  quotations      Quotation[]
  incomeContracts IncomeContract[]

  @@map("customers")
}

// ==================== 商务管理 ====================

model ProjectLead {
  id                    String    @id @default(cuid())
  projectSourceId       String    @unique @map("project_source_id")
  customerId            String    @map("customer_id")
  projectName           String    @map("project_name")
  location              String?
  contactPerson         String?   @map("contact_person")
  contactPhone          String?   @map("contact_phone")
  contactEmail          String?   @map("contact_email")
  projectNature         Json      @default("[]") @map("project_nature")
  implementationEntity  String    @map("implementation_entity")
  currentStatus         String    @default("跟踪中") @map("current_status")
  leadMode              String    @default("投标") @map("lead_mode")
  followUpRecords       Json      @default("[]") @map("follow_up_records")
  competitorInfo        Json      @default("[]") @map("competitor_info")
  tenderFiles           Json      @default("[]") @map("tender_files")
  tenderNo              String?   @map("tender_no")
  tenderDeadline        DateTime? @map("tender_deadline")
  bondAmount            Decimal?  @map("bond_amount") @db.Decimal(15, 2)
  bondPaymentStatus     String    @default("未付") @map("bond_payment_status")
  bondLendingId         String?   @map("bond_lending_id")
  biddingMethod         String?   @map("bidding_method")
  tenderDescription     String?   @db.Text @map("tender_description")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  lastModifiedBy     String?   @map("last_modified_by")

  customer   Customer     @relation(fields: [customerId], references: [id])
  project    Project?
  biddings   Bidding[]
  quotations Quotation[]

  @@map("project_leads")
}

model Bidding {
  id                String    @id @default(cuid())
  projectSourceId   String    @map("project_source_id")
  tenderFileReg     String?   @map("tender_file_registration")
  bidDeadline       DateTime? @map("bid_deadline")
  bondAmount        Decimal?  @map("bond_amount") @db.Decimal(15, 2)
  bondPaymentStatus String    @default("未付") @map("bond_payment_status")
  bidResult         String?   @map("bid_result")
  bidAmount         Decimal?  @map("bid_amount") @db.Decimal(15, 2)
  score             Decimal?
  failReason        String?   @map("fail_reason")
  attachmentUrl     String?   @map("attachment_url")
  tenderFileUrl     String?   @map("tender_file_url")
  bidFileUrl        String?   @map("bid_file_url")
  description       String?
  tenderFiles       Json      @default("[]") @map("tender_files")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  lastModifiedBy     String?   @map("last_modified_by")

  projectLead ProjectLead @relation(fields: [projectSourceId], references: [projectSourceId])

  @@map("biddings")
}

model Quotation {
  id                String   @id @default(cuid())
  projectSourceId   String?  @map("project_source_id")
  customerId        String   @map("customer_id")
  estimatedCost     Json     @default("{}") @map("estimated_cost")
  totalAmount       Decimal  @map("total_amount") @db.Decimal(15, 2)
  profitMargin      Decimal? @map("profit_margin") @db.Decimal(5, 2)
  approvalStatus    String   @default("草稿") @map("approval_status")
  version           Int      @default(1)
  adjustmentReason  String?  @map("adjustment_reason")
  status            String   @default("跟踪") @map("status")
  approvalInstanceId String? @map("approval_instance_id")
  quotationLetterUrl String? @map("quotation_letter_url")
  files              Json    @default("[]") @map("files")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  lastModifiedBy     String?   @map("last_modified_by")

  customer    Customer     @relation(fields: [customerId], references: [id])
  projectLead ProjectLead? @relation(fields: [projectSourceId], references: [projectSourceId])

  @@map("quotations")
}

// ==================== 项目管理 ====================

model Project {
  id                String    @id @default(cuid())
  projectSourceId   String    @unique @map("project_source_id")
  projectCode       String    @unique @map("project_code")
  name              String
  customerId        String    @map("customer_id")
  type              String?
  address           String?
  projectCategory   String?   @map("project_category")
  source            String    @default("投标中标")
  sourceRefId       String?   @map("source_ref_id")
  status            String    @default("执行")
  designManagerId   String?   @map("design_manager_id")
  supervisorLeaderId String?  @map("supervisor_leader_id")
  startDate         DateTime? @map("start_date")
  plannedEndDate    DateTime? @map("planned_end_date")
  actualCloseDate   DateTime? @map("actual_close_date")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  lastModifiedBy     String?   @map("last_modified_by")

  customer             Customer           @relation(fields: [customerId], references: [id])
  projectLead          ProjectLead        @relation(fields: [projectSourceId], references: [projectSourceId])
  designManager        User?              @relation("DesignManager", fields: [designManagerId], references: [id])
  supervisorLeader     User?              @relation("SupervisorLeader", fields: [supervisorLeaderId], references: [id])
  plans                ProjectPlan[]
  progressRecords     ProjectProgress[]
  designTasks         DesignTask[]
  outsourcingTasks    OutsourcingTask[]
  purchaseRequests    PurchaseRequest[]
  budgets             ProjectBudget[]
  incomeContracts     IncomeContract[]
  expenseContracts    ExpenseContract[]
  expenseReports      ExpenseReport[]
  receivables         Receivable[]
  payables            Payable[]
  nonContractIncomes  NonContractIncome[]
  nonContractExpenses NonContractExpense[]
  invoices            Invoice[]
  expenseReportItems  ExpenseReportItem[]

  @@map("projects")
}

model ProjectPlan {
  id              String   @id @default(cuid())
  projectSourceId String   @map("project_source_id")
  planType        String   @map("plan_type")
  planContent     String   @map("plan_content") @db.Text
  startDate       DateTime @map("start_date")
  endDate         DateTime @map("end_date")
  responsibleId   String?  @map("responsible_id")
  actualProgress  Int      @default(0) @map("actual_progress")
  status          String   @default("未开始")
  version         Int      @default(1)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  lastModifiedBy     String?   @map("last_modified_by")

  project           Project @relation(fields: [projectSourceId], references: [projectSourceId])
  responsiblePerson User?   @relation(fields: [responsibleId], references: [id])

  @@map("project_plans")
}

model ProjectProgress {
  id                String   @id @default(cuid())
  projectSourceId   String   @map("project_source_id")
  taskNode          String   @map("task_node")
  plannedPercentage Int      @default(0) @map("planned_percentage")
  actualPercentage  Int      @default(0) @map("actual_percentage")
  delayDays         Int      @default(0) @map("delay_days")
  alertStatus       String   @default("正常") @map("alert_status")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  lastModifiedBy     String?   @map("last_modified_by")

  project Project @relation(fields: [projectSourceId], references: [projectSourceId])

  @@map("project_progress")
}

model DesignTask {
  id              String    @id @default(cuid())
  projectSourceId String    @map("project_source_id")
  discipline      String?
  volume          String?
  drawingNo       String?   @map("drawing_no")
  assignedTo      String?   @map("assigned_to")
  plannedHours    Decimal?  @map("planned_hours") @db.Decimal(8, 1)
  actualHours     Decimal?  @map("actual_hours") @db.Decimal(8, 1)
  fileLink        String?   @map("file_link")
  changeRecord    Json      @default("[]") @map("change_record")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  lastModifiedBy     String?   @map("last_modified_by")

  project  Project @relation(fields: [projectSourceId], references: [projectSourceId])
  assignee User?   @relation(fields: [assignedTo], references: [id])

  @@map("design_tasks")
}

model OutsourcingTask {
  id                 String   @id @default(cuid())
  projectSourceId    String   @map("project_source_id")
  type               String   @default("to_person")
  targetName         String   @map("target_name")
  supplierId         String?  @map("supplier_id")
  contractId         String?  @map("contract_id")
  taskDescription    String   @map("task_description") @db.Text
  workload           String?
  deliveryDeadline   DateTime @map("delivery_deadline")
  amount             Decimal  @db.Decimal(15, 2)
  acceptanceStatus   String   @default("未验收") @map("acceptance_status")
  approvalStatus     String   @default("草稿") @map("approval_status")
  approvalInstanceId String?  @map("approval_instance_id")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  lastModifiedBy     String?   @map("last_modified_by")

  project  Project  @relation(fields: [projectSourceId], references: [projectSourceId])
  supplier Supplier? @relation(fields: [supplierId], references: [id])

  @@map("outsourcing_tasks")
}

// ==================== 采购管理 ====================

model PurchaseRequest {
  id                 String    @id @default(cuid())
  requestNo          String    @unique @map("request_no")
  projectSourceId    String    @map("project_source_id")
  requestType        String    @default("项目需求") @map("request_type")
  requiredDate       DateTime? @map("required_date")
  status             String    @default("草稿")
  approvalInstanceId String?   @map("approval_instance_id")
  attachments        Json      @default("[]") @map("attachments")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  lastModifiedBy     String?   @map("last_modified_by")

  project Project  @relation(fields: [projectSourceId], references: [projectSourceId])
  inquiry Inquiry?
  items   PurchaseRequestItem[]

  @@map("purchase_requests")
}

model PurchaseRequestItem {
  id                String    @id @default(cuid())
  purchaseRequestId String    @map("purchase_request_id")
  materialName      String    @map("material_name")
  spec              String?
  material          String?
  brand             String?
  standardNo        String?   @map("standard_no")
  unit              String?
  quantity          Decimal?  @db.Decimal(15, 2)
  remark            String?   @db.Text
  sortOrder         Int       @default(0) @map("sort_order")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  lastModifiedBy     String?   @map("last_modified_by")

  purchaseRequest PurchaseRequest @relation(fields: [purchaseRequestId], references: [id], onDelete: Cascade)
  supplierQuoteItems SupplierQuoteItem[]
  contractItems   ExpenseContractItem[]

  @@map("purchase_request_items")
}

model Inquiry {
  id                    String    @id @default(cuid())
  purchaseRequestId     String    @unique @map("purchase_request_id")
  projectSourceId       String    @map("project_source_id")
  supplierIds           Json      @default("[]") @map("supplier_ids")
  inquiryDate           DateTime  @default(now()) @map("inquiry_date")
  closingDate           DateTime? @map("closing_date")
  quoteSummary          Json      @default("{}") @map("quote_summary")
  recommendedSupplierId String?   @map("recommended_supplier_id")
  isSingleSource        Boolean   @default(false) @map("is_single_source")
  singleSourceReason    String?   @map("single_source_reason") @db.Text
  inquiryMode           String    @default("offline") @map("inquiry_mode")
  onlineToken           String?   @unique @map("online_token")
  onlineDeadline        DateTime? @map("online_deadline")
  onlineStatus          String    @default("pending") @map("online_status")
  attachments           Json      @default("[]") @map("attachments")
  currentRound          Int       @default(1) @map("current_round")
  confirmedSupplierId   String?   @map("confirmed_supplier_id")
  confirmedRound        Int?      @map("confirmed_round")
  status                String    @default("草稿") @map("status")
  approvalInstanceId    String?   @map("approval_instance_id")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  lastModifiedBy     String?   @map("last_modified_by")

  purchaseRequest  PurchaseRequest   @relation(fields: [purchaseRequestId], references: [id])
  expenseContract  ExpenseContract?
  supplierQuotes   SupplierQuote[]

  @@map("inquiries")
}

model SupplierQuote {
  id                String    @id @default(cuid())
  inquiryId         String    @map("inquiry_id")
  supplierId        String    @map("supplier_id")
  quoteMode         String    @default("offline") @map("quote_mode")
  unitPrice         Decimal?  @map("unit_price") @db.Decimal(15, 2)
  totalPrice        Decimal?  @map("total_price") @db.Decimal(15, 2)
  deliveryDays      Int?      @map("delivery_days")
  remark            String?   @db.Text
  attachments       Json      @default("[]") @map("attachments")
  quotedAt          DateTime? @map("quoted_at")
  isValid           Boolean   @default(true) @map("is_valid")
  round             Int       @default(1) @map("round")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  lastModifiedBy     String?   @map("last_modified_by")

  inquiry  Inquiry   @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  supplier Supplier  @relation(fields: [supplierId], references: [id])
  items    SupplierQuoteItem[]

  @@unique([inquiryId, supplierId, round])
  @@map("supplier_quotes")
}

model SupplierQuoteItem {
  id                    String    @id @default(cuid())
  supplierQuoteId       String    @map("supplier_quote_id")
  purchaseRequestItemId String    @map("purchase_request_item_id")
  unitPrice             Decimal?  @map("unit_price") @db.Decimal(15, 2)
  quantity              Decimal?  @db.Decimal(15, 2)
  totalPrice            Decimal?  @map("total_price") @db.Decimal(15, 2)
  deliveryDays          Int?      @map("delivery_days")
  remark                String?   @db.Text
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  lastModifiedBy     String?   @map("last_modified_by")

  supplierQuote     SupplierQuote        @relation(fields: [supplierQuoteId], references: [id], onDelete: Cascade)
  purchaseRequestItem PurchaseRequestItem @relation(fields: [purchaseRequestItemId], references: [id])

  @@map("supplier_quote_items")
}

model DeliveryReceipt {
  id                  String    @id @default(cuid())
  expenseContractId   String    @map("expense_contract_id")
  deliveryDate        DateTime  @default(now()) @map("delivery_date")
  deliveryAmount      Decimal?  @map("delivery_amount") @db.Decimal(15, 2)
  acceptedAmount      Decimal?  @map("accepted_amount") @db.Decimal(15, 2)
  invoiceAmount       Decimal?  @map("invoice_amount") @db.Decimal(15, 2)
  invoiceNo           String?   @map("invoice_no")
  inspectionResult    String    @default("待检") @map("inspection_result")
  receiptStatus       String    @default("待验收") @map("receipt_status")
  invoiceMatched      Boolean   @default(false) @map("invoice_matched")
  attachments         String    @default("[]") @map("attachments") @db.Text
  status              String    @default("草稿") @map("status")
  approvalInstanceId  String?   @map("approval_instance_id")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  lastModifiedBy     String?   @map("last_modified_by")

  expenseContract ExpenseContract @relation(fields: [expenseContractId], references: [id])
  items           DeliveryReceiptItem[]

  @@map("delivery_receipts")
}

model DeliveryReceiptItem {
  id                  String    @id @default(cuid())
  deliveryReceiptId   String    @map("delivery_receipt_id")
  contractItemId      String?   @map("contract_item_id")
  materialName        String    @map("material_name")
  spec                String?
  unit                String?
  orderedQuantity     Decimal?  @map("ordered_quantity") @db.Decimal(15, 2)
  receivedQuantity    Decimal?  @map("received_quantity") @db.Decimal(15, 2)
  acceptedQuantity    Decimal?  @map("accepted_quantity") @db.Decimal(15, 2)
  unitPrice           Decimal?  @map("unit_price") @db.Decimal(15, 2)
  inspectionResult    String    @default("待检") @map("inspection_result")
  remark              String?   @db.Text
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  lastModifiedBy     String?   @map("last_modified_by")

  deliveryReceipt  DeliveryReceipt     @relation(fields: [deliveryReceiptId], references: [id], onDelete: Cascade)
  contractItem     ExpenseContractItem? @relation(fields: [contractItemId], references: [id])

  @@map("delivery_receipt_items")
}

// ==================== 合同管理 ====================

model IncomeContract {
  id                 String    @id @default(cuid())
  contractNo         String    @unique @map("contract_no")
  projectSourceId    String?   @map("project_source_id")
  customerId         String    @map("customer_id")
  signedDate         DateTime? @map("signed_date")
  totalAmount        Decimal   @map("total_amount") @db.Decimal(15, 2)
  splitStages        Json      @default("[]") @map("split_stages")
  status             String    @default("草稿")
  approvalInstanceId String?   @map("approval_instance_id")
  scannedUrl         String?   @map("scanned_url")
  archivedUrl        String?   @map("archived_url")
  invoicedAmount     Decimal?  @default(0) @map("invoiced_amount") @db.Decimal(15, 2)
  taxRate            String?   @map("tax_rate")
  pricingMethod      String?   @map("pricing_method")
  contractSummary    String?   @map("contract_summary") @db.Text
  paymentTerms       String?   @map("payment_terms") @db.Text
  lastModifiedBy     String?   @map("last_modified_by")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  customer Customer @relation(fields: [customerId], references: [id])
  project  Project? @relation(fields: [projectSourceId], references: [projectSourceId])

  @@map("income_contracts")
}

model ExpenseContract {
  id                 String    @id @default(cuid())
  contractNo         String    @unique @map("contract_no")
  projectSourceId    String?   @map("project_source_id")
  supplierId         String?   @map("supplier_id")
  inquiryId          String?   @unique @map("inquiry_id")
  signedDate         DateTime? @map("signed_date")
